# --- Database ---
# Postgres on Railway. For local dev use the public proxy URL
# (Railway -> Postgres service -> Settings -> Public Networking).
# In Vercel/Railway runtime, use the internal URL: postgres.railway.internal
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# --- Cloudflare R2 (S3-compatible object storage) ---
# Cloudflare dashboard -> R2 -> Manage R2 API Tokens (Object Read & Write,
# scoped to the bucket). The dialog gives Access Key ID + Secret Access Key.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="amantis-shop"
# Public r2.dev URL (or future custom domain like https://cdn.example.com)
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# --- Auth.js ---
# Required. Sign/verify JWT session tokens. Generate with `openssl rand -base64 32`.
AUTH_SECRET=""
# Auth.js auto-detects this from the request, but set explicitly when running
# behind a proxy or for non-default ports.
# AUTH_URL="https://amantis-shop.vercel.app"

# --- Resend (transactional email) ---
# Used by the password recovery flow. Create a key at resend.com/api-keys.
RESEND_API_KEY=""
# Optional override for the From address. Defaults to "Ámantis <onboarding@resend.dev>"
# (Resend's testing sender — only delivers to the email registered on the
# Resend account). For production, verify a domain in Resend and set:
# RESEND_FROM="Ámantis <no-reply@amantis.mx>"
RESEND_FROM=""

# --- Seed (used by `pnpm db:seed`) ---
# The admin account created/refreshed by prisma/seed.ts. Plaintext is hashed
# with bcrypt at seed time and never stored. Change before sharing with Shirley.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME=""
